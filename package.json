{
  "name": "aicultor",
  "version": "1.0.0",
  "private": true,
  "description": "AIcultor - AI-powered plant collection manager with personalized care plans",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vercel dev",
    "build": "echo 'No build step required for static site'",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint api/**/*.js",
    "lint:css": "stylelint 'frontend/**/*.css' || echo 'No CSS files to lint'",
    "format": "prettier --write '**/*.{js,json,css,html,md}'",
    "format:check": "prettier --check '**/*.{js,json,css,html,md}'",
    "security:audit": "npm audit --production",
    "security:check": "npm audit --audit-level=moderate",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "eslint": "^8.57.0",
    "jest": "^30.3.0",
    "node-fetch": "^2.7.0",
    "prettier": "^3.2.5",
    "stylelint": "^16.2.1",
    "stylelint-config-standard": "^36.0.0"
  },
  "keywords": [
    "plants",
    "garden",
    "ai",
    "anthropic",
    "claude",
    "plant-care",
    "vercel"
  ],
  "author": "",
  "license": "MIT"
}
